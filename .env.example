# --- İsteğe bağlı (değiştirmezsen varsayılanlar kullanılır) ---
# ORIGIN=YVR
# DESTINATION=ESB
# START_DATE=2026-08-17
# END_DATE=2026-08-31
# CURRENCY=CAD
# ADULTS=1

# Bu fiyatın altına düşünce ekstra uyarı (🎯). Boş bırakırsan kapalı.
# PRICE_THRESHOLD=1100

# true: her çalışmada özet at. false: sadece fiyat düşünce / hedefin altında uyar.
# NOTIFY_ALWAYS=true

# Boş = sınırsız aktarma. 0 = sadece direkt. 1 = en fazla 1 aktarma.
# MAX_STOPS=

# Mesajda kaç tarih listelensin
# TOP_N=3

# Amadeus ortamı. Gerçek fiyatlar için uygulamanı "Production"a taşıyıp burayı bırak.
# Sadece deneme/sandbox için: https://test.api.amadeus.com
# AMADEUS_BASE=https://api.amadeus.com
